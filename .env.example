# =============================================================================
# Browser application environment variables (VITE_*)
# =============================================================================
# Copy ONLY the VITE_* browser variables below into .env.local for local frontend
# development. Find values in Supabase Dashboard → Project Settings → API.
# =============================================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Legacy fallback for older local setups only.
# Keep VITE_SUPABASE_PUBLISHABLE_KEY as the canonical key for new environments.
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# =============================================================================
# Supabase Edge Function runtime secrets
# =============================================================================
# Do NOT place these in .env.local. They are not loaded by the Vite browser
# app. Configure them via the Supabase Dashboard (Project Settings → Edge
# Functions → Secrets) or with `supabase secrets set` before deploying or
# serving edge functions locally.
# =============================================================================

# Required for the symptom-analyzer edge function to call the AI gateway.
# LOVABLE_API_KEY=your_lovable_api_key

# Optional Upstash Redis credentials for distributed rate limiting.
# The function falls back to in-memory rate limiting when these are absent.
# UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Supabase runtime secrets for auth-validating and admin edge functions.
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Required for the broadcast-emergency edge function when SMS alerts are used.
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Optional shared secret for webhook-triggered cache invalidation.
# WEBHOOK_SECRET=your_webhook_secret
